{
  "_comment": "Declared branch-protection posture for this repo (issue #577, ADR 0004). Edit here, then `make branch-protection-apply`. `make branch-protection-check` reports drift read-only.",
  "branch": "main",
  "protection": {
    "required_status_checks": {
      "strict": true,
      "contexts": [
        "ci/woodpecker/pr/woodpecker"
      ]
