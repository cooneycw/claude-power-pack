# Woodpecker CI - Server (Claude Power Pack /cicd:woodpecker template)
#
# One server instance. Agents connect from other hosts via the gRPC port.
# Secrets are pulled from AWS Secrets Manager by bootstrap-secrets.py.example
# into docker.env (gitignored) - do not commit forge credentials.
#
# Setup:
#   1. python3 bootstrap-secrets.py --secret-name my-woodpecker-secret
#   2. Edit WOODPECKER_ADMIN below to your forge username.
#   3. docker compose -f docker-compose.server.yml up -d
#
# Pin the image digest and rotate it (Renovate) - never use :latest.
# Docs: https://woodpecker-ci.org/docs/administration/server-config

services:
  woodpecker-server:
    image: woodpeckerci/woodpecker-server:v3.13.0
    container_name: woodpecker-server
    ports:
      - "9000:8000"   # web UI + API
      - "9001:9000"   # agent gRPC - keep private (Tailscale/LAN only)
    volumes:
      - woodpecker-server-data:/var/lib/woodpecker/
    env_file: docker.env   # WOODPECKER_GITHUB_CLIENT/SECRET, WOODPECKER_AGENT_SECRET, WOODPECKER_HOST
    environment:
      - WOODPECKER_OPEN=true
      # Forge: Woodpecker also supports Gitea/Forgejo/GitLab/Bitbucket - swap this
      # WOODPECKER_<FORGE> block per https://woodpecker-ci.org/docs/administration/forges
      - WOODPECKER_GITHUB=true
      - WOODPECKER_ADMIN=CHANGE_ME   # <- your forge username
      # Privileged plugins are an allowlist - list ONLY what you use. buildx is
      # needed only if you build/scan container images in CI.
      - WOODPECKER_PLUGINS_PRIVILEGED=woodpeckerci/plugin-docker-buildx,plugins/docker
    restart: unless-stopped

volumes:
  woodpecker-server-data:
