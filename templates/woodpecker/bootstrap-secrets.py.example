#!/usr/bin/env python3
"""Pull Woodpecker server secrets from AWS Secrets Manager into a docker .env.

Generalized template (Claude Power Pack /cicd:woodpecker). Copy next to your
Woodpecker server compose file and run before `docker compose up`. The output
`docker.env` is gitignored and referenced by the compose `env_file:`.

Usage:
    python3 bootstrap-secrets.py --secret-name my-woodpecker-secret
    python3 bootstrap-secrets.py --secret-name my-woodpecker-secret \\
        --region us-east-1 --keys WOODPECKER_GITHUB_CLIENT WOODPECKER_GITHUB_SECRET

The named AWS secret is expected to be a JSON object. Only the requested keys
are written to docker.env (missing keys are skipped, not errors).
"""
from __future__ import annotations

import argparse
import json
import os

import boto3

# Keys a Woodpecker server typically needs. Override with --keys.
DEFAULT_KEYS = [
    "WOODPECKER_GITHUB_CLIENT",
    "WOODPECKER_GITHUB_SECRET",
    "WOODPECKER_AGENT_SECRET",
    "WOODPECKER_HOST",
]


def main() -> None:
    parser = argparse.ArgumentParser(description=__doc__)
    parser.add_argument(
        "--secret-name",
        required=True,
        help="AWS Secrets Manager secret id (a JSON object).",
    )
    parser.add_argument(
        "--region",
        default=os.environ.get("AWS_DEFAULT_REGION", "us-east-1"),
        help="AWS region (default: $AWS_DEFAULT_REGION or us-east-1).",
    )
    parser.add_argument(
        "--keys",
        nargs="+",
        default=DEFAULT_KEYS,
        help="Secret keys to write to docker.env.",
    )
    parser.add_argument(
        "--out",
        default="docker.env",
        help="Output env file (default: docker.env, next to this script).",
    )
    args = parser.parse_args()

    session = boto3.Session(
        aws_access_key_id=os.environ.get("AWS_ACCESS_KEY_ID"),
        aws_secret_access_key=os.environ.get("AWS_SECRET_ACCESS_KEY"),
        region_name=args.region,
    )
    client = session.client("secretsmanager")
    resp = client.get_secret_value(SecretId=args.secret_name)
    secrets = json.loads(resp["SecretString"])

    out_path = args.out
    if not os.path.isabs(out_path):
        out_path = os.path.join(os.path.dirname(os.path.abspath(__file__)), out_path)

    written = []
    with open(out_path, "w") as f:
        for key in args.keys:
            if key in secrets:
                f.write(f"{key}={secrets[key]}\n")
                written.append(key)

    print(f"Wrote {out_path} with {len(written)} key(s) from {args.secret_name}: "
          f"{', '.join(written) or '(none matched)'}")


if __name__ == "__main__":
    main()
